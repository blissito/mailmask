{
  "name": "@easybits.cloud/mailmask",
  "version": "0.1.3",
  "description": "Official SDK for the MailMask email alias/forwarding API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "mailmask",
    "email",
    "alias",
    "forwarding",
    "sdk"
  ],
  "license": "MIT"
}
